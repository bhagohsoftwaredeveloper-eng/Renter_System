DB_USER=postgres
DB_HOST=localhost
DB_NAME=renter_systems
DB_PASSWORD=password
DB_PORT=5432
PORT=5000
JWT_SECRET=yoursecret
BIOMETRIC_BRIDGE_URL=http://127.0.0.1:5003

# --- Cloud / public deployment (e.g. Railway) ---
# Railway's Postgres provides DATABASE_URL. Reference it in the service variables
# as ${{Postgres.DATABASE_URL}}. The code reads it (see db.js). Leave unset locally.
# DATABASE_URL=
# SSL is ON by default when DATABASE_URL is set. If you connect over Railway's
# INTERNAL network (…railway.internal), set DB_SSL=false to avoid an SSL error.
# DB_SSL=true

# API auth. When set, the matching routes require an `x-api-key` header.
# Leave BLANK locally to keep auth disabled. Generate strong random values for cloud.
#   API_KEY        -> terminal / admin endpoints (set on the SecureAccess terminal)
#   MOBILE_API_KEY -> RenterNotify app push endpoints (embedded in the app config)
API_KEY=
MOBILE_API_KEY=

# Set to 'true' on first cloud boot to auto-create the schema from init_db.sql
# (idempotent). Safe to leave 'true', or set 'false' after the first deploy.
RUN_DB_INIT=false

# --- Email (for sending renters their Renter Notify QR code) ---
# SMTP credentials. When unset, the QR-email endpoints return 503 (disabled).
# Gmail example: host smtp.gmail.com, port 587, user = your address, pass = a
# Google "App Password" (not your normal password). Or use SendGrid/Mailgun SMTP.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Renter Notify <you@example.com>
