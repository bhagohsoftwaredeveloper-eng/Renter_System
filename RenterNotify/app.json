{
  "expo": {
    "name": "Renter Notify",
    "slug": "renter-notify",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "package": "com.servequeue.renternotify",
      "useNextNotificationsApi": true,
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE"]
    },
    "ios": {
      "bundleIdentifier": "com.servequeue.renternotify",
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0F766E"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:5005",
      "mobileApiKey": "",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
