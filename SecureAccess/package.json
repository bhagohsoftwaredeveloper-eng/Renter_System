{
  "name": "secure-access-app",
  "version": "1.2.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron": "electron electron/main.js",
    "electron:admin": "electron electron/main.js --admin",
    "electron:terminal": "electron electron/main.js --terminal",
    "build:web": "npx expo export --platform web",
    "package": "npm run build:web && node scripts/fix-paths.js && electron-builder build --win --x64"
  },
  "build": {
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "appId": "com.servequeue.app",
    "productName": "ServeQueue",
    "directories": {
      "output": "release"
    },
    "icon": "assets/serveQueue.png",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/serveQueue.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "electron/installer.nsh"
    }
  },
  "dependencies": {
    "@digitalpersona/devices": "^0.2.6",
    "@digitalpersona/fingerprint": "^1.0.0",
    "@digitalpersona/services": "^0.2.8",
    "@expo-google-fonts/public-sans": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "async": "^3.2.6",
    "axios": "^1.13.6",
    "big-integer": "^1.6.52",
    "expo": "~55.0.5",
    "expo-font": "^55.0.4",
    "expo-print": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.4",
    "sjcl": "^1.0.9"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^55.0.12",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^3.3.2",
    "typescript": "~5.9.2"
  }
}
